# ══════════════════════════════════════════════════════════════════════════════
# AegisAI — Environment Configuration Template
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the actual .env file to source control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=AegisAI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Groq API (https://console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=2048

# ── OpenRouter fallback (https://openrouter.ai) ───────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=AegisAI

# ── Sarvam AI (https://dashboard.sarvam.ai) ───────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_DEFAULT_LANGUAGE=en-IN

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=aegisai
MONGODB_TASKS_COLLECTION=tasks
MONGODB_OUTCOMES_COLLECTION=outcomes
MONGODB_REFLECTIONS_COLLECTION=reflections

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # uncomment if auth is enabled
REDIS_TTL_SECONDS=3600

# ── Pinecone Semantic Search ─────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=aegis-task-semantic
PINECONE_HOST=https://your-index-host.pinecone.io
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1024
PINECONE_METRIC=cosine
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ── JWT / Authentication ──────────────────────────────────────────────────────
JWT_SECRET_KEY=generate_with_python_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
BCRYPT_ROUNDS=10

# ── Feature Flags ─────────────────────────────────────────────────────────────
STREAMING_ENABLED=true
SEMANTIC_MEMORY_ENABLED=true
ETHICS_AGENT_ENABLED=false
PARALLEL_AGENTS_ENABLED=true
RED_TEAM_ENABLED=false
TEMPORAL_MONITOR_ENABLED=false
ANALYTICS_ENABLED=true

# ── Pipeline Controls ─────────────────────────────────────────────────────────
TRUST_REVISION_THRESHOLD=65
MAX_REVISION_ATTEMPTS=2
TEMPORAL_CHECK_INTERVAL_HOURS=24
TEMPORAL_ALERT_THRESHOLD=6

# ── Deployment ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Used by frontend/src/services/api.ts via frontend/assets/js/config.js
VITE_API_BASE_URL=http://localhost:8000

# ── Trust Engine Weights (6D model, must sum to 1.0) ─────────────────────────
TRUST_WEIGHT_GOAL_CLARITY=0.15
TRUST_WEIGHT_INFORMATION_QUALITY=0.20
TRUST_WEIGHT_EXECUTION_FEASIBILITY=0.25
TRUST_WEIGHT_RISK_MANAGEABILITY=0.15
TRUST_WEIGHT_RESOURCE_ADEQUACY=0.15
TRUST_WEIGHT_EXTERNAL_UNCERTAINTY=0.10

# ── Legacy Trust Weights (4D compatibility only) ─────────────────────────────
TRUST_WEIGHT_SUCCESS_RATE=0.4
TRUST_WEIGHT_DATA_COMPLETENESS=0.3
TRUST_WEIGHT_FEASIBILITY=0.2
TRUST_WEIGHT_COMPLEXITY_INVERSE=0.1

# ── Risk Thresholds ───────────────────────────────────────────────────────────
RISK_HIGH_THRESHOLD=45.0
RISK_MEDIUM_THRESHOLD=72.0
